{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Leaf Nest",
  "version": "0.1.0",
  "identifier": "com.leafnest.reader",
  "build": {
    "beforeDevCommand": "pnpm dev:web",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm build:web",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Leaf Nest",
        "width": 1280,
        "height": 800,
        "minWidth": 360,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["main"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico", "../public/logo.png"],
    "android": {
      "minSdkVersion": 24
    }
  }
}
