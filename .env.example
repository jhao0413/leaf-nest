# Public app origin used by the browser during local development.
APP_URL=http://localhost:5173
API_PORT=8787
DATABASE_URL=postgres://postgres:postgres@localhost:5432/leaf_nest
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
BETTER_AUTH_URL=http://localhost:8787
# Internal endpoint used by the backend to reach S3-compatible storage.
# In Docker Compose, this can be an internal service name such as http://minio:9000.
S3_ENDPOINT=http://localhost:9000
# Public endpoint embedded into signed URLs returned to the browser.
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=leaf-nest
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# Optional Docker Compose self-host overrides. Leave these unset for the local defaults
# from docker-compose.yml, or set them when deploying the stack on a remote host/domain.
# SELF_HOST_APP_URL=https://reader.example.com
# SELF_HOST_BETTER_AUTH_URL=https://reader.example.com
# SELF_HOST_S3_ENDPOINT=http://minio:9000
# SELF_HOST_S3_PUBLIC_ENDPOINT=https://objects.example.com
