{
  "name": "leaf-nest",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "author": "Jhao <jhao413@qq.com>",
  "repository": "git@github.com:jhao0413/leaf-nest.git",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently -n web,api \"pnpm dev:web\" \"pnpm dev:api\"",
    "dev:web": "vp dev",
    "dev:api": "tsx watch server/src/index.ts",
    "build": "pnpm build:web && pnpm build:api",
    "build:web": "vp build",
    "build:api": "tsc -p tsconfig.server.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "preview": "vp preview",
    "lint": "vp lint",
    "fmt": "vp fmt",
    "check": "vp check",
    "test": "pnpm test:web && pnpm test:api",
    "test:web": "vp test",
    "test:api": "node node_modules/vitest/vitest.mjs run --config vitest.server.config.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.924.0",
    "@aws-sdk/s3-request-presigner": "^3.924.0",
    "@heroui/button": "2.2.26",
    "@heroui/card": "2.2.24",
    "@heroui/checkbox": "2.3.26",
    "@heroui/dropdown": "2.3.26",
    "@heroui/image": "2.2.16",
    "@heroui/input": "2.4.27",
    "@heroui/kbd": "^2.2.21",
    "@heroui/menu": "2.2.25",
    "@heroui/modal": "2.2.23",
    "@heroui/slider": "2.4.23",
    "@heroui/system": "2.4.22",
    "@heroui/theme": "2.4.22",
    "@heroui/tooltip": "2.2.23",
    "@radix-ui/react-scroll-area": "^1.2.1",
    "@radix-ui/react-slider": "^1.2.1",
    "@hono/node-server": "^1.19.6",
    "better-auth": "^1.3.13",
    "dayjs": "^1.11.13",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.44.7",
    "framer-motion": "^12.23.16",
    "hono": "^4.9.12",
    "jszip": "^3.10.1",
    "lodash": "^4.17.21",
    "lucide-react": "^0.468.0",
    "motion": "^11.13.1",
    "pg": "^8.16.3",
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "react-router-dom": "^7.9.4",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^11.0.3",
    "zod": "^4.1.12",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.13",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/lodash": "^4.17.13",
    "@types/node": "^20",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@types/pg": "^8.15.6",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.5",
    "jsdom": "^26.1.0",
    "postcss": "^8",
    "tailwindcss": "^4.1.13",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.1.14",
    "vite-plus": "0.1.14",
    "vitest": "npm:@voidzero-dev/vite-plus-test@0.1.14"
  },
  "packageManager": "pnpm@9.0.0"
}
